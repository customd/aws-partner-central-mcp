{
  "name": "aws-partner-central-mcp-server",
  "version": "1.0.5",
  "description": "MCP server bridging Claude Desktop to the AWS Partner Central 3.0 agent endpoint. Handles AWS IAM Identity Center (SSO) authentication and SigV4 request signing transparently.",
  "type": "module",
  "main": "server/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/customd/aws-partner-central-mcp.git"
  },
  "homepage": "https://github.com/customd/aws-partner-central-mcp#readme",
  "bugs": {
    "url": "https://github.com/customd/aws-partner-central-mcp/issues"
  },
  "bin": {
    "aws-partner-central-mcp-server": "server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf server/*.js server/*.js.map server/*.d.ts server/services server/tools server/schemas",
    "rebuild": "npm run clean && npm run build",
    "start": "node server/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "for f in test/*.test.mjs; do echo \"\\n# $f\"; node \"$f\" || exit 1; done",
    "prepack:mcpb": "npm run clean && npm run build && npm prune --omit=dev",
    "pack:mcpb": "mcpb pack . dist/aws-partner-central.mcpb",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-s3": "^3.1056.0",
    "@aws-sdk/client-sso": "^3.700.0",
    "@aws-sdk/client-sso-oidc": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@smithy/protocol-http": "^5.0.0",
    "@smithy/signature-v4": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "aws",
    "partner-central",
    "claude",
    "claude-desktop"
  ],
  "license": "MIT"
}
